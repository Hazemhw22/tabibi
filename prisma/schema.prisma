generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  PATIENT
  DOCTOR
  CLINIC_ADMIN
  PLATFORM_ADMIN
}

enum AppointmentStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum DoctorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum TransactionType {
  SERVICE   // خدمة مقدمة - مبلغ سالب (دين على المريض)
  PAYMENT   // دفعة من المريض - مبلغ موجب
}

enum ClinicAppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================================
// AUTH MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          Role      @default(PATIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  doctorProfile Doctor?
  appointments  Appointment[] @relation("PatientAppointments")
  reviews       Review[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// MEDICAL MODELS
// ============================================================

model Specialty {
  id      String   @id @default(cuid())
  name    String   @unique
  nameAr  String
  icon    String?
  doctors Doctor[]
}

model Doctor {
  id              String       @id @default(cuid())
  userId          String       @unique
  specialtyId     String
  bio             String?
  experienceYears Int          @default(0)
  consultationFee Float        @default(0)
  licenseNumber   String?
  status          DoctorStatus @default(PENDING)
  rating          Float        @default(0)
  totalReviews    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty          Specialty          @relation(fields: [specialtyId], references: [id])
  clinics            Clinic[]
  timeSlots          TimeSlot[]
  appointments       Appointment[]
  reviews            Review[]
  clinicPatients     ClinicPatient[]
  clinicAppointments ClinicAppointment[]
}

model Clinic {
  id       String  @id @default(cuid())
  doctorId String
  name     String
  address  String
  city     String  @default("الخليل")
  phone    String?
  mapUrl   String?
  isMain   Boolean @default(false)

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model TimeSlot {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  clinicId        String?
  timeSlotId      String?
  appointmentDate DateTime
  startTime       String
  endTime         String
  status          AppointmentStatus @default(DRAFT)
  paymentStatus   PaymentStatus     @default(UNPAID)
  notes           String?
  fee             Float
  stripePaymentId String?
  stripeSessionId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient  User      @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor   Doctor    @relation(fields: [doctorId], references: [id])
  clinic   Clinic?   @relation(fields: [clinicId], references: [id])
  timeSlot TimeSlot? @relation(fields: [timeSlotId], references: [id])
  payment  Payment?
  review   Review?
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  amount          Float
  currency        String        @default("ILS")
  method          String        @default("stripe")
  status          PaymentStatus @default(UNPAID)
  stripeIntentId  String?
  stripeSessionId String?
  metadata        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String   @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  patient     User        @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ============================================================
// CLINIC PATIENT MANAGEMENT (إدارة مرضى العيادة)
// ============================================================

/// سجل المريض في عيادة الطبيب (مستقل عن حساب المنصة)
model ClinicPatient {
  id          String    @id @default(cuid())
  doctorId    String
  /// ربط اختياري بحساب المنصة
  userId      String?
  name        String
  phone       String?
  email       String?
  dateOfBirth DateTime?
  gender      String?   // male | female
  address     String?
  bloodType   String?
  allergies   String?
  notes       String?
  fileNumber  String?   // رقم الملف
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor             Doctor               @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  transactions       ClinicTransaction[]
  clinicAppointments ClinicAppointment[]
}

/// المعاملات المالية: خدمات (دين سالب) أو دفعات (موجب)
model ClinicTransaction {
  id               String          @id @default(cuid())
  clinicPatientId  String
  type             TransactionType
  description      String
  /// المبلغ المطلق - الإشارة تُحدد من النوع (SERVICE=سالب، PAYMENT=موجب)
  amount           Float
  date             DateTime        @default(now())
  notes            String?
  createdBy        String?         // doctor user id
  createdAt        DateTime        @default(now())

  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}

/// مواعيد تُضاف من قِبل الطبيب للمريض
model ClinicAppointment {
  id              String                  @id @default(cuid())
  doctorId        String
  clinicPatientId String
  title           String
  date            DateTime
  time            String
  duration        Int                     @default(30) // minutes
  notes           String?
  status          ClinicAppointmentStatus @default(SCHEDULED)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}
