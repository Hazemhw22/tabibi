generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  PATIENT
  DOCTOR
  CLINIC_ADMIN
  PLATFORM_ADMIN
  MEDICAL_CENTER_ADMIN // مدير المركز — إشراف كامل وحسابات وموظفون
  MEDICAL_CENTER_RECEPTIONIST // استقبال — مواعيد، تسجيل مرضى، تحصيل
  MEDICAL_CENTER_LAB_STAFF // مختبر/أشعة — رفع نتائج لملف المريض
}

enum AppointmentStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum DoctorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum TransactionType {
  SERVICE // خدمة مقدمة - مبلغ سالب (دين على المريض)
  PAYMENT // دفعة من المريض - مبلغ موجب
}

enum ClinicAppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

// ============================================================
// AUTH MODELS
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  regionId      String? // منطقة المريض (مدينة/قرية من الضفة الغربية)
  role          Role      @default(PATIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  doctorProfile            Doctor?
  appointments             Appointment[]             @relation("PatientAppointments")
  reviews                  Review[]
  /// خطط علاج من أطباء المنصة (مريض مسجل User)
  platformPatientCarePlans PlatformPatientCarePlan[]

  /// عند أدوار موظفي المركز: معرف المركز
  medicalCenterId String?
  medicalCenter   MedicalCenter? @relation("MedicalCenterStaff", fields: [medicalCenterId], references: [id], onDelete: SetNull)
  /// بيانات الموظف داخل المركز (تُعبأ يدوياً)
  staffType       String? // مثال: محاسب، نظافة، استقبال...
  educationLevel  String? // مثال: دبلوم، بكالوريوس
  salaryMonthly   Float?
  attendanceNotes String?        @db.Text

  medicalCenterPatientDocsAsPatient MedicalCenterPatientDocument[] @relation("MedicalCenterDocPatient")
  medicalCenterPatientDocsUploaded  MedicalCenterPatientDocument[] @relation("MedicalCenterDocUploader")

  sentMessages MessageLog[] @relation("MessageLogSender")
}

/// سجل رسائل SMS/WhatsApp داخل المنصة
model MessageLog {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String
  createdByRole   Role
  medicalCenterId String?
  doctorId        String?

  provider         String        @default("ASTRA")
  channel          String        @default("SMS") // SMS | WHATSAPP
  to               String
  body             String        @db.Text
  status           MessageStatus @default(PENDING)
  providerResponse String?       @db.Text

  createdBy     User           @relation("MessageLogSender", fields: [createdByUserId], references: [id], onDelete: Cascade)
  medicalCenter MedicalCenter? @relation("MedicalCenterMessageLogs", fields: [medicalCenterId], references: [id], onDelete: SetNull)
  doctor        Doctor?        @relation("DoctorMessageLogs", fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
  @@index([medicalCenterId, createdAt])
  @@index([doctorId, createdAt])
  @@index([status, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// MEDICAL MODELS
// ============================================================

model Specialty {
  id      String   @id @default(cuid())
  name    String   @unique
  nameAr  String
  icon    String?
  doctors Doctor[]
}

/// مركز طبي (مجموعة أطباء تحت سقف واحد)
model MedicalCenter {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  nameAr              String?
  address             String
  city                String    @default("الخليل")
  phone               String?
  locationId          String?
  description         String?
  imageUrl            String?
  isActive            Boolean   @default(true)
  /// PENDING | APPROVED | REJECTED — موافقة مشرف المنصة + اشتراك سنوي 1500 ₪
  approvalStatus      String    @default("APPROVED")
  subscriptionEndDate DateTime?
  /// JSON: [{ "dayOfWeek": 0-6, "startTime": "09:00", "endTime": "17:00" }] — أوقات عمل المركز (للعرض والإدارة)
  operatingHoursJson  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  staffUsers       User[]                         @relation("MedicalCenterStaff")
  doctors          Doctor[]
  emergencyVisits  EmergencyVisit[]
  appointments     Appointment[]                  @relation("CenterAppointments")
  /// عيادات مرتبطة بهذا المركز (فرع المركز لكل طبيب)
  linkedClinics    Clinic[]
  doctorInvites    MedicalCenterDoctorInvite[]
  patientDocuments MedicalCenterPatientDocument[]
  messageLogs      MessageLog[]                   @relation("MedicalCenterMessageLogs")
}

/// نتيجة تحليل أو أشعة يُرفعها موظف المركز لمريض المنصة
model MedicalCenterPatientDocument {
  id               String   @id @default(cuid())
  medicalCenterId  String
  patientUserId    String
  /// LAB | IMAGING
  category         String
  title            String
  fileUrl          String
  fileName         String?
  mimeType         String?
  uploadedByUserId String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  medicalCenter MedicalCenter @relation(fields: [medicalCenterId], references: [id], onDelete: Cascade)
  patient       User          @relation("MedicalCenterDocPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  uploadedBy    User?         @relation("MedicalCenterDocUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([medicalCenterId, patientUserId])
}

/// زيارة طوارئ بدون حجز مسبق
model EmergencyVisit {
  id                 String        @id @default(cuid())
  medicalCenterId    String
  patientName        String
  complaint          String? // الشكوى / المرض
  amount             Float
  paymentStatus      PaymentStatus @default(UNPAID)
  paymentMethod      String? // نقدي، بطاقة، ...
  notes              String?
  registeredByUserId String?
  createdAt          DateTime      @default(now())

  medicalCenter MedicalCenter @relation(fields: [medicalCenterId], references: [id], onDelete: Cascade)
}

/// مطابق لجدول Doctor في Supabase (الحقول والمعاني كما في لوحة البيانات)
model Doctor {
  id              String       @id @default(cuid())
  userId          String       @unique
  specialtyId     String
  bio             String?
  experienceYears Int          @default(0)
  consultationFee Float        @default(0)
  licenseNumber   String?
  status          DoctorStatus @default(PENDING)
  rating          Float        @default(0)
  totalReviews    Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  /// basic | premium | enterprise
  subscriptionPlan      String?
  /// monthly | half_year | yearly
  subscriptionPeriod    String?
  /// تاريخ انتهاء الاشتراك
  subscriptionEndDate   DateTime?
  /// رقم الواتساب للتواصل
  whatsapp              String?
  visibleToPatients     Boolean   @default(true)
  /// معرف الموقع من قائمة مدن وقرى الضفة الغربية
  locationId            String?
  /// إن وُجد: الطبيب ضمن هذا المركز الطبي (يظهر في صفحة المركز)
  medicalCenterId       String?
  /// مستحقات الطبيب من العيادة (حساب الطبيب) — المريض يدفع للمركز وليس مباشرة للطبيب
  doctorClinicFee       Float     @default(0)
  /// true إذا سمح مشرف المنصة بإضافة عيادة جديدة (زيادة سعر)
  canAddExtraClinics    Boolean   @default(false)
  /// CONSULTATION | EXAMINATION — للعرض بجانب السعر للمريض
  patientFeeServiceType String    @default("CONSULTATION")
  /// MALE | FEMALE
  gender                String?

  user                     User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty                Specialty                   @relation(fields: [specialtyId], references: [id])
  medicalCenter            MedicalCenter?              @relation(fields: [medicalCenterId], references: [id], onDelete: SetNull)
  clinics                  Clinic[]
  timeSlots                TimeSlot[]
  appointments             Appointment[]
  reviews                  Review[]
  clinicPatients           ClinicPatient[]
  clinicAppointments       ClinicAppointment[]
  medicalNotes             ClinicMedicalNote[]
  patientCarePlans         ClinicPatientCarePlan[]
  platformPatientCarePlans PlatformPatientCarePlan[]
  medicalCenterInvites     MedicalCenterDoctorInvite[]
  messageLogs              MessageLog[]                @relation("DoctorMessageLogs")
}

/// طلب من مركز طبي لربط طبيب مسجّل مسبقاً — يظهر للطبيب للموافقة أو الرفض
model MedicalCenterDoctorInvite {
  id                    String    @id @default(cuid())
  medicalCenterId       String
  doctorId              String
  /// PENDING | ACCEPTED | REJECTED
  status                String    @default("PENDING")
  consultationFee       Float
  doctorClinicFee       Float     @default(0)
  patientFeeServiceType String    @default("CONSULTATION")
  proposedTimeSlotsJson String    @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  respondedAt           DateTime?

  medicalCenter MedicalCenter @relation(fields: [medicalCenterId], references: [id], onDelete: Cascade)
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([medicalCenterId, status])
  @@index([doctorId, status])
}

model Clinic {
  id              String  @id @default(cuid())
  doctorId        String
  name            String
  address         String
  city            String  @default("الخليل")
  phone           String?
  mapUrl          String?
  isMain          Boolean @default(false)
  locationId      String? // منطقة هذه العيادة (مدينة/قرية من الضفة الغربية)
  /// عند الربط بمركز طبي (فرع المركز للطبيب)
  medicalCenterId String?

  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  medicalCenter MedicalCenter? @relation(fields: [medicalCenterId], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  timeSlots     TimeSlot[]
}

model TimeSlot {
  id           String   @id @default(cuid())
  doctorId     String
  clinicId     String?
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean  @default(true)
  /// عدد الحجوزات المسموحة لنفس الدور (نفس الفترة) — مثلاً 2 يعني دوران في نفس الوقت
  slotCapacity Int      @default(1)
  createdAt    DateTime @default(now())

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic       Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  appointments Appointment[]
}

model Appointment {
  id                      String            @id @default(cuid())
  patientId               String
  doctorId                String
  clinicId                String?
  timeSlotId              String?
  appointmentDate         DateTime
  startTime               String
  endTime                 String
  status                  AppointmentStatus @default(DRAFT)
  paymentStatus           PaymentStatus     @default(UNPAID)
  notes                   String?
  /// ما يدفعه المريض للمركز (إيراد المركز من الاستشارة)
  fee                     Float
  /// عند الحجز عبر طبيب مرتبط بمركز: معرف المركز
  medicalCenterId         String?
  /// لقطة لمستحقات الطبيب من العيادة وقت الحجز (حساب الطبيب)
  doctorClinicFeeSnapshot Float?
  stripePaymentId         String?
  stripeSessionId         String?
  /// رقم الدور ضمن نفس الفترة (1..slotCapacity) — يحدد المريض أي دور يحجز
  slotTurn                Int?
  /// يطابق followUpVisits[].id في خطة العلاج — لعرض الموعد في لوحة المريض بعد حفظ الخطة
  carePlanFollowUpId      String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  patient       User           @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  clinic        Clinic?        @relation(fields: [clinicId], references: [id])
  timeSlot      TimeSlot?      @relation(fields: [timeSlotId], references: [id])
  medicalCenter MedicalCenter? @relation("CenterAppointments", fields: [medicalCenterId], references: [id], onDelete: SetNull)
  payment       Payment?
  review        Review?
}

model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  amount          Float
  currency        String        @default("ILS")
  method          String        @default("stripe")
  status          PaymentStatus @default(UNPAID)
  stripeIntentId  String?
  stripeSessionId String?
  metadata        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String   @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  patient     User        @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ============================================================
// CLINIC PATIENT MANAGEMENT (إدارة مرضى العيادة)
// ============================================================

/// سجل المريض في عيادة الطبيب (مستقل عن حساب المنصة)
model ClinicPatient {
  id          String    @id @default(cuid())
  doctorId    String
  /// ربط اختياري بحساب المنصة
  userId      String?
  name        String
  phone       String?
  whatsapp    String? // رقم الواتساب لإرسال رسائل الدفعات والديون
  email       String?
  dateOfBirth DateTime?
  gender      String? // male | female
  address     String?
  bloodType   String?
  allergies   String?
  notes       String?
  fileNumber  String? // رقم الملف
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  doctor             Doctor                 @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  transactions       ClinicTransaction[]
  clinicAppointments ClinicAppointment[]
  medicalNotes       ClinicMedicalNote[]
  carePlan           ClinicPatientCarePlan?
}

/// خطة علاجية حسب تخصص الطبيب (بيانات مرنة JSON + ملاحظات الطبيب)
model ClinicPatientCarePlan {
  id              String   @id @default(cuid())
  doctorId        String
  clinicPatientId String   @unique
  /// FETAL_IMAGING | OB_GYN | PEDIATRICS | ORTHOPEDICS | NEPHROLOGY | UROLOGY_NEPHROLOGY | CARDIOLOGY |
  /// PSYCHIATRY | OPHTHALMOLOGY | ENT | PHYSICAL_MEDICINE_REHAB | SPORTS_MEDICINE | OCCUPATIONAL_MEDICINE |
  /// GASTROENTEROLOGY | ENDOCRINOLOGY | RHEUMATOLOGY | INFECTIOUS_DISEASE | ONCOLOGY | HEMATOLOGY | PULMONOLOGY |
  /// DENTAL | GENERIC — وحقل data.intlClinical للخطط المنظمة
  planType        String
  /// بيانات الخطة: followUpVisits[] على الجذر (موحّد)، intlClinical، إلخ
  data            Json     @default("{}")
  doctorNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}

/// خطة علاج لمريض المنصة (حساب User) لدى طبيب محدد
model PlatformPatientCarePlan {
  id            String   @id @default(cuid())
  doctorId      String
  patientUserId String
  /// نفس قيم planType في ClinicPatientCarePlan
  planType      String
  data          Json     @default("{}")
  doctorNotes   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctor  Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient User   @relation(fields: [patientUserId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientUserId])
}

/// المعاملات المالية: خدمات (دين سالب) أو دفعات (موجب)
model ClinicTransaction {
  id              String          @id @default(cuid())
  clinicPatientId String
  type            TransactionType
  description     String
  /// المبلغ المطلق - الإشارة تُحدد من النوع (SERVICE=سالب، PAYMENT=موجب)
  amount          Float
  date            DateTime        @default(now())
  notes           String?
  createdBy       String? // doctor user id
  createdAt       DateTime        @default(now())

  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}

/// مواعيد تُضاف من قِبل الطبيب للمريض
model ClinicAppointment {
  id              String                  @id @default(cuid())
  doctorId        String
  clinicPatientId String
  title           String
  date            DateTime
  time            String
  duration        Int                     @default(30) // minutes
  notes           String?
  status          ClinicAppointmentStatus @default(SCHEDULED)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}

/// ملاحظات / ملفات طبية متعددة لكل مريض عيادة
model ClinicMedicalNote {
  id              String   @id @default(cuid())
  doctorId        String
  clinicPatientId String
  allergies       String? // حساسية / تنبيهات تخص هذه الملاحظة
  diagnosis       String? // الحالة المرضية الأساسية
  treatment       String? // ما قام به الطبيب / خطة العلاج
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinicPatient ClinicPatient @relation(fields: [clinicPatientId], references: [id], onDelete: Cascade)
}
